{
  "name": "solera-repo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/*"
  ],
  "overrides": {
    "@hono/node-server": "1.19.11",
    "@tailwindcss/oxide": {
      "tar": "7.5.11"
    },
    "eslint": {
      "flatted": "3.4.1"
    },
    "hono": "4.12.8",
    "lodash": "4.17.23"
  },
  "scripts": {
    "dev": "node scripts/dev-orchestrator.mjs",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run start:dev",
    "build": "npm run build:api && npm run build:web",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "staking:devnet:env:check": "node scripts/validate-staking-devnet-env.mjs",
    "staking:devnet:sync-ids": "node scripts/sync-staking-program-ids.mjs devnet",
    "staking:devnet:build": "npm run staking:devnet:env:check && npm run staking:devnet:sync-ids && node scripts/run-anchor-command.mjs build",
    "staking:devnet:deploy": "npm run staking:devnet:env:check && npm run staking:devnet:sync-ids && node scripts/run-anchor-command.mjs deploy",
    "staking:mainnet:dry-run": "node scripts/validate-staking-mainnet-dry-run.mjs",
    "staking:test": "node scripts/run-rust-command.mjs test --workspace",
    "start": "npm --workspace apps/web run start",
    "lint": "npm run lint:web",
    "lint:web": "npm --workspace apps/web run lint",
    "lint:api": "npm --workspace apps/api run lint",
    "lint:all": "npm run lint:web && npm run lint:api",
    "clean": "npm run clean:web && npm run clean:api",
    "clean:web": "npm --workspace apps/web run clean",
    "clean:api": "node -e \"require('fs').rmSync('apps/api/dist', { recursive: true, force: true })\"",
    "db:migrate:deploy": "npm --workspace apps/api run prisma:migrate:deploy",
    "db:migrate:status": "npm --workspace apps/api run prisma:migrate:status",
    "db:generate": "npm --workspace apps/api run prisma:generate"
  }
}
